<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>CULytics Member Login</title>

<style>

body{
    font-family:Arial,sans-serif;
    max-width:500px;
    margin:50px auto;
    text-align:center;
}

input{
    width:100%;
    padding:12px;
    margin:15px 0;
}

button{
    background:#0B2341;
    color:white;
    border:none;
    padding:12px 25px;
    cursor:pointer;
}

#message{
    margin-top:20px;
}

</style>

</head>

<body>

<h1>CULytics Member Access</h1>

<p>Enter your email address.</p>

<input
    type="email"
    id="email"
    placeholder="Email Address"
>

<button onclick="sendOTP()">
Send Login Code
</button>

<div id="message"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script>

const supabase = window.supabase.createClient(
    'https://tkwpqjekdwwacqxwmmri.supabase.co',
    'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRrd3BxamVrZHd3YWNxeHdtbXJpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAxNTg1MDIsImV4cCI6MjA5NTczNDUwMn0.ppYBTNyhopXJJ7ASE9Y3oPXeuXhX3nlXiYTEObD2mD4'
);

async function sendOTP(){

    const email =
        document.getElementById('email').value;

    const { error } =
        await supabase.auth.signInWithOtp({
            email: email
        });

    const message =
        document.getElementById('message');

    if(error){
        message.innerHTML =
            "Error: " + error.message;
    }
    else{
        message.innerHTML =
            "Check your email for the login code.";
    }
}

</script>

</body>
</html>
